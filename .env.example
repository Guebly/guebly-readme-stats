# ── Frontend (.env) ─────────────────────────────────────
# These are exposed to the browser (VITE_ prefix)
VITE_API_BASE_URL=
VITE_SITE_NAME=Guebly ReadMe Stats
VITE_SITE_URL=https://readme.stats.guebly.com.br
VITE_LOGO_URL=https://www.guebly.com.br/guebly.png
VITE_GUEBLY_URL=https://www.guebly.com.br

# ── Backend (Vercel Environment Variables) ──────────────
# These go in Vercel Dashboard > Settings > Environment Variables
# NEVER put these in .env — they must stay server-side only.
#
# GH_TOKEN_1=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GH_TOKEN_2=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  (optional, for more rate limit)
# GH_TOKEN_3=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  (optional)
#
# Optional overrides:
# ALLOWED_USERS=user1,user2          (restrict access to specific users)
# ALLOWED_GISTS=gistid1,gistid2      (restrict access to specific gists)
# BLOCKED_USERS=user1,user2          (block specific users)
# EXCLUDE_REPOS=repo1,repo2          (exclude repos from star counts)
# CACHE_DURATION=86400               (override cache TTL in seconds)
# MULTI_PAGE_STARS=true              (enable multi-page star fetching)
