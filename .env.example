# ── Frontend (.env) ─────────────────────────────────────
# These are exposed to the browser (VITE_ prefix)
VITE_API_BASE_URL=
VITE_SITE_NAME=Guebly ReadMe Stats
VITE_SITE_URL=https://readme.stats.guebly.com.br
VITE_LOGO_URL=https://www.guebly.com.br/guebly.png
VITE_GUEBLY_URL=https://www.guebly.com.br

# ── Backend (Vercel Environment Variables) ──────────────
# These go in Vercel Dashboard > Settings > Environment Variables
# NEVER put these in .env — they must stay server-side only.
#
# PAT_1=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PAT_2=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  (optional, for more rate limit)
# PAT_3=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  (optional)
